# Supabase public configuration for Astro SSR.
# Keep real local values in .env.local, which is ignored by git.
# Do not place secret keys, database passwords, JWT secrets, or remote credentials here.

PUBLIC_SUPABASE_URL="https://replace-with-project-ref.supabase.co"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"
