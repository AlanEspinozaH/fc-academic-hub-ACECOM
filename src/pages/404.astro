---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina no encontrada" description="La pagina solicitada no existe.">
	<section class="page-heading" aria-labelledby="not-found-title">
		<p class="kicker">404</p>
		<h1 id="not-found-title">Pagina no encontrada</h1>
		<p>La ruta solicitada no existe en la etapa actual de FC Academic Hub.</p>
		<div class="actions">
			<a class="button" href="/">Volver al inicio</a>
			<a class="text-link" href="/courses">Ver cursos demo</a>
		</div>
	</section>
</Layout>
