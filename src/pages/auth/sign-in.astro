---
import { createSignInPageModel } from '../../domain/auth/sign-in-page';
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const model = createSignInPageModel({
	authStatus: Astro.locals.auth.status,
	rawError: Astro.url.searchParams.get('error'),
	rawNext: Astro.url.searchParams.get('next'),
});

if (model.authenticatedRedirect) {
	return Astro.redirect(model.authenticatedRedirect, 303);
}
---

<Layout
	title="Acceso institucional"
	description="Acceso institucional para FC Academic Hub mediante Google OAuth administrado por Supabase Auth."
>
	<section class="sign-in" aria-labelledby="sign-in-title">
		<div class="page-heading">
			<p class="kicker">Acceso institucional</p>
			<h1 id="sign-in-title">Continua con tu correo habilitado</h1>
			<p>
				El acceso requiere una cuenta institucional habilitada. Google confirma la identidad y FC
				Academic Hub valida la cuenta en el servidor.
			</p>
		</div>

		{
			model.errorMessage && (
				<p class="auth-message" role="status">
					{model.errorMessage}
				</p>
			)
		}

		<form class="sign-in-form" method="post" action={model.formAction}>
			<input type="hidden" name="next" value={model.next} />
			<button type="submit" disabled={!model.isConfigured}>Continuar con Google</button>
		</form>
	</section>
</Layout>

<script>
	import { clearInheritedUrlFragment } from '../../domain/auth/browser-url';

	clearInheritedUrlFragment({
		hash: window.location.hash,
		pathname: window.location.pathname,
		search: window.location.search,
		replaceUrl: (url) => window.history.replaceState(null, '', url),
	});
</script>

<style>
	.sign-in {
		display: grid;
		max-width: 42rem;
		gap: 1rem;
	}

	.auth-message {
		margin: 0;
		border-left: 4px solid var(--color-accent);
		background: var(--color-surface-muted);
		color: var(--color-text);
		padding: 0.75rem 0.85rem;
	}

	.sign-in-form {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.sign-in-form button {
		min-height: 2.55rem;
		border: 0;
		border-radius: var(--radius);
		background: var(--color-primary);
		color: var(--color-bg);
		cursor: pointer;
		font-weight: 750;
		padding: 0.55rem 0.85rem;
	}

	.sign-in-form button:hover:not(:disabled) {
		background: var(--color-primary-strong);
	}

	.sign-in-form button:disabled {
		cursor: not-allowed;
		opacity: 0.68;
	}
</style>
