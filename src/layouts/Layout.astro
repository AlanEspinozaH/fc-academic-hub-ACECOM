---
import { siteConfig } from '../config/site';

interface Props {
	description?: string;
	title?: string;
}

const { description = siteConfig.description, title = siteConfig.name } = Astro.props;
const pageTitle = title === siteConfig.name ? title : title + ' | ' + siteConfig.name;
const currentPath = Astro.url.pathname;

const isActivePath = (href: string) => {
	if (href === '/') {
		return currentPath === href;
	}

	return currentPath === href || currentPath.startsWith(href + '/');
};
---

<!doctype html>
<html lang={siteConfig.locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<script is:inline>
			(() => {
				const storageKey = 'fc-academic-hub-theme';
				const root = document.documentElement;
				try {
					const storedTheme = localStorage.getItem(storageKey);
					const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
						? 'dark'
						: 'light';
					const theme =
						storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : systemTheme;
					root.dataset.theme = theme;
					root.style.colorScheme = theme;
				} catch {
					root.dataset.theme = 'light';
				}
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<a class="skip-link" href="#content">Saltar al contenido principal</a>
		<header class="site-header">
			<div class="header-inner">
				<a class="brand" href="/" aria-label={siteConfig.name + ' - inicio'}>
					<span class="brand-mark" aria-hidden="true">FC</span>
					<span class="brand-text">{siteConfig.name}</span>
				</a>
				<div class="header-actions">
					<nav class="site-nav" aria-label="Navegacion principal">
						<ul>
							{
								siteConfig.navigation.map((item) => (
									<li>
										<a href={item.href} aria-current={isActivePath(item.href) ? 'page' : undefined}>
											{item.label}
										</a>
									</li>
								))
							}
						</ul>
					</nav>
					<button
						class="theme-toggle"
						type="button"
						data-theme-toggle
						aria-label="Cambiar tema de color"
					>
						<span>Tema</span>
						<span data-theme-toggle-icon aria-hidden="true">Auto</span>
					</button>
				</div>
			</div>
		</header>
		<main id="content" class="page-shell">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="footer-inner">
				<p>{siteConfig.name} - {siteConfig.stage}</p>
				<p>
					Catalogo academico publico con acceso institucional mediante Google y Supabase; sin
					documentos reales ni R2.
				</p>
			</div>
		</footer>
		<script is:inline>
			(() => {
				const storageKey = 'fc-academic-hub-theme';
				const root = document.documentElement;
				const button = document.querySelector('[data-theme-toggle]');
				const icon = document.querySelector('[data-theme-toggle-icon]');
				if (!(button instanceof HTMLButtonElement) || icon === null) {
					return;
				}

				const getTheme = () => (root.dataset.theme === 'dark' ? 'dark' : 'light');
				const syncButton = () => {
					const theme = getTheme();
					button.setAttribute(
						'aria-label',
						theme === 'dark' ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro',
					);
					button.setAttribute('aria-pressed', String(theme === 'dark'));
					icon.textContent = theme === 'dark' ? 'Oscuro' : 'Claro';
				};

				button.addEventListener('click', () => {
					const nextTheme = getTheme() === 'dark' ? 'light' : 'dark';
					root.dataset.theme = nextTheme;
					root.style.colorScheme = nextTheme;
					try {
						localStorage.setItem(storageKey, nextTheme);
					} catch {
						// La preferencia queda solo para la sesion actual si storage no esta disponible.
					}
					syncButton();
				});

				syncButton();
			})();
		</script>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-bg: #f7f9fb;
		--color-surface: #ffffff;
		--color-surface-muted: #e8f3f0;
		--color-chip-muted: #f1f4f6;
		--color-text: #18212f;
		--color-muted: #52606f;
		--color-border: #d8e1e8;
		--color-primary: #0f6b6e;
		--color-primary-strong: #094c4f;
		--color-accent: #9c5b12;
		--color-header-bg: rgb(255 255 255 / 0.94);
		--color-footer-bg: #18212f;
		--color-footer-text: rgb(255 255 255 / 0.82);
		--shadow-soft: 0 8px 22px rgb(24 33 47 / 0.06);
		--radius: 8px;
		font-family:
			Inter,
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			sans-serif;
	}

	@media (prefers-color-scheme: dark) {
		:root:not([data-theme='light']) {
			color-scheme: dark;
			--color-bg: #10161d;
			--color-surface: #18212b;
			--color-surface-muted: #20332f;
			--color-chip-muted: #222c36;
			--color-text: #eef3f8;
			--color-muted: #a8b4c0;
			--color-border: #334252;
			--color-primary: #62bdb7;
			--color-primary-strong: #9bdcd7;
			--color-accent: #e0ae62;
			--color-header-bg: rgb(16 22 29 / 0.95);
			--color-footer-bg: #0b1016;
			--color-footer-text: #c6d0dc;
			--shadow-soft: 0 8px 22px rgb(0 0 0 / 0.22);
		}
	}

	:root[data-theme='dark'] {
		color-scheme: dark;
		--color-bg: #10161d;
		--color-surface: #18212b;
		--color-surface-muted: #20332f;
		--color-chip-muted: #222c36;
		--color-text: #eef3f8;
		--color-muted: #a8b4c0;
		--color-border: #334252;
		--color-primary: #62bdb7;
		--color-primary-strong: #9bdcd7;
		--color-accent: #e0ae62;
		--color-header-bg: rgb(16 22 29 / 0.95);
		--color-footer-bg: #0b1016;
		--color-footer-text: #c6d0dc;
		--shadow-soft: 0 8px 22px rgb(0 0 0 / 0.22);
	}

	:root[data-theme='light'] {
		color-scheme: light;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--color-bg);
		color: var(--color-text);
	}

	body {
		min-width: 320px;
		min-height: 100vh;
		margin: 0;
		line-height: 1.55;
	}

	body,
	button,
	input,
	select,
	textarea {
		font: inherit;
	}

	a {
		color: var(--color-primary);
		text-underline-offset: 0.18em;
	}

	a:hover {
		color: var(--color-primary-strong);
	}

	a:focus-visible,
	button:focus-visible,
	input:focus-visible,
	select:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--color-primary), white 25%);
		outline-offset: 3px;
	}

	p,
	h1,
	h2,
	h3 {
		overflow-wrap: break-word;
	}

	p,
	ul {
		margin-top: 0;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		z-index: 10;
		transform: translateY(-150%);
		border-radius: var(--radius);
		background: var(--color-text);
		color: var(--color-bg);
		padding: 0.55rem 0.75rem;
		text-decoration: none;
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	.site-header {
		border-bottom: 1px solid var(--color-border);
		background: var(--color-header-bg);
	}

	.header-inner,
	.footer-inner,
	.page-shell {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		padding: 0.7rem 0;
	}

	.header-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.5rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--color-text);
		font-weight: 750;
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 2.1rem;
		height: 2.1rem;
		place-items: center;
		border-radius: var(--radius);
		background: var(--color-primary);
		color: var(--color-bg);
		font-size: 0.82rem;
		letter-spacing: 0;
	}

	.brand-text {
		font-size: 0.98rem;
		letter-spacing: 0;
	}

	.site-nav ul {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.25rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-nav a,
	.theme-toggle {
		display: inline-flex;
		min-height: 2.25rem;
		align-items: center;
		border-radius: var(--radius);
		font-size: 0.92rem;
	}

	.site-nav a {
		color: var(--color-muted);
		padding: 0.35rem 0.55rem;
		text-decoration: none;
	}

	.site-nav a[aria-current='page'] {
		background: var(--color-surface-muted);
		color: var(--color-primary-strong);
		font-weight: 700;
	}

	.theme-toggle {
		gap: 0.35rem;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		color: var(--color-text);
		cursor: pointer;
		font-weight: 750;
		padding: 0.3rem 0.55rem;
	}

	.theme-toggle [data-theme-toggle-icon] {
		color: var(--color-muted);
		font-size: 0.82rem;
	}

	.page-shell {
		padding: 2rem 0 3rem;
	}

	.section {
		margin-top: 2rem;
	}

	.kicker {
		margin-bottom: 0.35rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.page-heading h1 {
		max-width: 18ch;
		margin: 0 0 0.6rem;
		font-size: clamp(1.8rem, 3vw, 2.55rem);
		line-height: 1.08;
		letter-spacing: 0;
	}

	.page-heading p {
		max-width: 64ch;
		margin-bottom: 0;
		color: var(--color-muted);
		font-size: 1rem;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: 1rem;
	}

	.button,
	.text-link {
		display: inline-flex;
		min-height: 2.55rem;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius);
		font-weight: 750;
	}

	.button {
		background: var(--color-primary);
		color: var(--color-bg);
		padding: 0.55rem 0.85rem;
		text-decoration: none;
	}

	.button:hover {
		background: var(--color-primary-strong);
		color: var(--color-bg);
	}

	.text-link {
		padding: 0.55rem 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.info-list {
		display: grid;
		gap: 0.75rem;
		padding: 0;
		list-style: none;
	}

	.info-list li {
		border-left: 4px solid var(--color-primary);
		padding-left: 0.8rem;
	}

	.info-list strong {
		display: block;
		margin-bottom: 0.15rem;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0 0 0 0);
		white-space: nowrap;
	}

	.empty-state {
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		color: var(--color-muted);
		padding: 0.85rem;
	}

	.site-footer {
		border-top: 1px solid var(--color-border);
		background: var(--color-footer-bg);
		color: var(--color-footer-text);
	}

	.footer-inner {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 0.8rem;
		padding: 1rem 0;
	}

	.footer-inner p {
		margin: 0;
	}

	@media (max-width: 780px) {
		.header-inner {
			align-items: flex-start;
			flex-direction: column;
		}

		.header-actions {
			justify-content: flex-start;
		}

		.site-nav ul {
			justify-content: flex-start;
		}

		.grid {
			grid-template-columns: 1fr;
		}

		.page-heading h1 {
			max-width: 100%;
			font-size: 2rem;
		}
	}
</style>
