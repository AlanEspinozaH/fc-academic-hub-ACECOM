---
import { siteConfig } from '../config/site';

interface Props {
	description?: string;
	title?: string;
}

const { description = siteConfig.description, title = siteConfig.name } = Astro.props;
const pageTitle = title === siteConfig.name ? title : title + ' | ' + siteConfig.name;
const currentPath = Astro.url.pathname;

const isActivePath = (href: string) => {
	if (href === '/') {
		return currentPath === href;
	}

	return currentPath === href || currentPath.startsWith(href + '/');
};
---

<!doctype html>
<html lang={siteConfig.locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<a class="skip-link" href="#content">Saltar al contenido principal</a>
		<header class="site-header">
			<div class="header-inner">
				<a class="brand" href="/" aria-label={siteConfig.name + ' - inicio'}>
					<span class="brand-mark" aria-hidden="true">FC</span>
					<span class="brand-text">{siteConfig.name}</span>
				</a>
				<nav class="site-nav" aria-label="Navegacion principal">
					<ul>
						{
							siteConfig.navigation.map((item) => (
								<li>
									<a href={item.href} aria-current={isActivePath(item.href) ? 'page' : undefined}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>
		</header>
		<main id="content" class="page-shell">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="footer-inner">
				<p>{siteConfig.name} - {siteConfig.stage}</p>
				<p>Sin autenticacion, documentos reales, Supabase ni R2 en esta etapa.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-bg: #f8fafc;
		--color-surface: #ffffff;
		--color-surface-muted: #eef6f4;
		--color-text: #18212f;
		--color-muted: #52606f;
		--color-border: #d8e1e8;
		--color-primary: #0f6b6e;
		--color-primary-strong: #094c4f;
		--color-accent: #9c5b12;
		--shadow-soft: 0 16px 40px rgb(24 33 47 / 0.08);
		--radius: 8px;
		font-family:
			Inter,
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--color-bg);
		color: var(--color-text);
	}

	body {
		min-width: 320px;
		min-height: 100vh;
		margin: 0;
		line-height: 1.6;
	}

	body,
	button,
	input,
	select,
	textarea {
		font: inherit;
	}

	a {
		color: var(--color-primary);
		text-underline-offset: 0.18em;
	}

	a:hover {
		color: var(--color-primary-strong);
	}

	a:focus-visible,
	button:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--color-primary), white 25%);
		outline-offset: 3px;
	}

	p,
	h1,
	h2,
	h3 {
		overflow-wrap: break-word;
	}

	p,
	ul {
		margin-top: 0;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		z-index: 10;
		transform: translateY(-150%);
		border-radius: var(--radius);
		background: var(--color-text);
		color: white;
		padding: 0.65rem 0.9rem;
		text-decoration: none;
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	.site-header {
		border-bottom: 1px solid var(--color-border);
		background: rgb(255 255 255 / 0.94);
	}

	.header-inner,
	.footer-inner,
	.page-shell {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		color: var(--color-text);
		font-weight: 750;
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 2.4rem;
		height: 2.4rem;
		place-items: center;
		border-radius: var(--radius);
		background: var(--color-primary);
		color: white;
		font-size: 0.9rem;
		letter-spacing: 0;
	}

	.brand-text {
		font-size: 1rem;
		letter-spacing: 0;
	}

	.site-nav ul {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-nav a {
		display: inline-flex;
		min-height: 2.5rem;
		align-items: center;
		border-radius: var(--radius);
		color: var(--color-muted);
		padding: 0.45rem 0.75rem;
		text-decoration: none;
	}

	.site-nav a[aria-current='page'] {
		background: var(--color-surface-muted);
		color: var(--color-primary-strong);
		font-weight: 700;
	}

	.page-shell {
		padding: 3rem 0 4rem;
	}

	.section {
		margin-top: 3rem;
	}

	.kicker {
		margin-bottom: 0.5rem;
		color: var(--color-accent);
		font-size: 0.85rem;
		font-weight: 750;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
		gap: 2rem;
		align-items: stretch;
	}

	.hero-copy h1,
	.page-heading h1 {
		max-width: 12ch;
		margin: 0 0 1rem;
		font-size: clamp(2.25rem, 7vw, 4.8rem);
		line-height: 0.98;
		letter-spacing: 0;
	}

	.hero-copy p,
	.page-heading p {
		max-width: 64ch;
		color: var(--color-muted);
		font-size: 1.1rem;
	}

	.hero-panel {
		align-self: end;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		box-shadow: var(--shadow-soft);
		padding: 1.25rem;
	}

	.hero-panel h2 {
		margin: 0 0 0.8rem;
		font-size: 1.15rem;
	}

	.hero-panel ul {
		display: grid;
		gap: 0.7rem;
		margin-bottom: 0;
		padding-left: 1.2rem;
		color: var(--color-muted);
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	.button,
	.text-link {
		display: inline-flex;
		min-height: 2.75rem;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius);
		font-weight: 750;
	}

	.button {
		background: var(--color-primary);
		color: white;
		padding: 0.65rem 1rem;
		text-decoration: none;
	}

	.button:hover {
		background: var(--color-primary-strong);
		color: white;
	}

	.text-link {
		padding: 0.65rem 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.info-list {
		display: grid;
		gap: 1rem;
		padding: 0;
		list-style: none;
	}

	.info-list li {
		border-left: 4px solid var(--color-primary);
		padding-left: 1rem;
	}

	.info-list strong {
		display: block;
		margin-bottom: 0.2rem;
	}

	.site-footer {
		border-top: 1px solid var(--color-border);
		background: var(--color-text);
		color: rgb(255 255 255 / 0.82);
	}

	.footer-inner {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.25rem 0;
	}

	.footer-inner p {
		margin: 0;
	}

	@media (max-width: 780px) {
		.header-inner {
			align-items: flex-start;
			flex-direction: column;
		}

		.site-nav ul {
			justify-content: flex-start;
		}

		.hero,
		.grid {
			grid-template-columns: 1fr;
		}

		.hero-copy h1,
		.page-heading h1 {
			max-width: 100%;
			font-size: 2.5rem;
		}
	}
</style>
