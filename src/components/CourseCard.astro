---
import type { CourseCatalogItem } from '../domain/catalog-view';

interface Props {
	href?: string;
	item: CourseCatalogItem;
}

const { item, href = '/courses/' + item.course.slug } = Astro.props;
const titleId = item.course.id + '-title';
const cycleLabels = [
	...new Set(
		item.offerings.map((offering) => 'Ciclo ' + offering.curriculumCourse.recommendedCycle),
	),
];
const programLabels = [...new Set(item.offerings.map((offering) => offering.program.abbreviation))];
---

<article class="course-card" aria-labelledby={titleId}>
	<p class="course-card__meta">
		<span>{item.course.code}</span>
		<span>{item.course.credits} creditos</span>
	</p>
	<h2 id={titleId}><a href={href}>{item.course.name}</a></h2>
	<p>{item.course.summary}</p>
	<p class="course-card__line">
		{programLabels.join(', ')}{cycleLabels.length > 0 ? ' · ' + cycleLabels.join(', ') : ''}
	</p>
</article>

<style>
	.course-card {
		display: grid;
		gap: 0.55rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		box-shadow: var(--shadow-soft);
		padding: 0.85rem;
	}

	.course-card__meta,
	.course-card__line {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.88rem;
		font-weight: 700;
	}

	.course-card__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.course-card__meta span {
		border-radius: 999px;
		background: var(--color-surface-muted);
		color: var(--color-primary-strong);
		line-height: 1.2;
		padding: 0.25rem 0.5rem;
	}

	h2 {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.25;
		letter-spacing: 0;
	}

	h2 a {
		color: var(--color-text);
		text-decoration-thickness: 0.08em;
	}

	p {
		margin: 0;
		color: var(--color-muted);
	}
</style>
