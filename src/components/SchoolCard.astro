---
import { formatAcademicUnitDescription, type AcademicUnit } from '../domain/academic-unit';

interface Props {
	courseCount: number;
	curriculumCount: number;
	school: AcademicUnit;
}

const { courseCount, curriculumCount, school } = Astro.props;
const titleId = school.id + '-title';
const schoolDescription = formatAcademicUnitDescription(school);
---

<article class="school-card" aria-labelledby={titleId}>
	<div class="school-card__mark" aria-hidden="true">{school.abbreviation}</div>
	<div class="school-card__body">
		<h2 id={titleId}><a href={'/schools/' + school.slug}>{school.name}</a></h2>
		<p>{schoolDescription}</p>
		<p class="school-card__meta">{curriculumCount} planes · {courseCount} cursos</p>
	</div>
</article>

<style>
	.school-card {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 0.8rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		padding: 0.85rem;
	}

	.school-card__mark {
		display: grid;
		width: 2.7rem;
		height: 2.7rem;
		place-items: center;
		border-radius: var(--radius);
		background: var(--color-primary);
		color: white;
		font-size: 0.78rem;
		font-weight: 800;
	}

	.school-card__body {
		display: grid;
		gap: 0.35rem;
	}

	h2 {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.25;
	}

	h2 a {
		color: var(--color-text);
	}

	p {
		margin: 0;
		color: var(--color-muted);
	}

	.school-card__meta {
		font-size: 0.88rem;
		font-weight: 750;
	}

	@media (max-width: 520px) {
		.school-card {
			grid-template-columns: 1fr;
		}
	}
</style>
