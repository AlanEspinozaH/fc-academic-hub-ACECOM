		"@types/node": "^26.1.1",
		"eslint": "^10.7.0",
		"prettier": "^3.9.6",
		"prettier-plugin-astro": "^0.14.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.65.0",
		"vitest": "^4.1.10",
		"wrangler": "^4.112.0"
